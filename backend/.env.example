# ==================== REQUIRED ====================

# MongoDB connection string (Atlas or local)
# Local:  mongodb://localhost:27017/wavechat
# Atlas:  mongodb+srv://user:pass@cluster.xxxxx.mongodb.net/wavechat?retryWrites=true&w=majority
DATABASE_URL="mongodb://localhost:27017/wavechat"

# JWT secrets — generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-random-string
JWT_REFRESH_SECRET=change-me-to-another-random-string
ADMIN_JWT_SECRET=change-me-to-a-third-random-string

JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Frontend URL for CORS (your Vercel or custom domain)
FRONTEND_URL=http://localhost:5173

# ==================== OPTIONAL ====================

# Redis — leave blank to run without Redis
REDIS_URL=

# Port (Render sets this automatically, leave blank to default to 3000)
PORT=3000
NODE_ENV=development

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Must match the callback registered in Google Cloud Console
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# Cloudinary — REQUIRED for production file uploads (local dev stores on disk)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# SMTP — for email OTP verification (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Twilio — for phone OTP verification (optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Admin credentials (created on first deploy if they don't exist)
ADMIN_EMAIL=admin@wavechat.com
ADMIN_PASSWORD=Admin@123
