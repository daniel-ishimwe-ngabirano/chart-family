# Backend API URL (your Render deployment URL)
# In dev: leave blank (uses Vite proxy to localhost:3000)
# In prod: https://your-app.onrender.com
VITE_API_URL=https://wavechart.onrender.com

# TURN/ICE servers for WebRTC calls (required for calls across different networks)
# Paste the full ICE servers array from Metered.ca "Show ICE Servers Array"
# as a single-line JSON string:
VITE_ICE_SERVERS=[{"urls":"stun:stun.relay.metered.ca:80"},{"urls":"turn:global.relay.metered.ca:80","username":"xxx","credential":"xxx"},{"urls":"turn:global.relay.metered.ca:80?transport=tcp","username":"xxx","credential":"xxx"},{"urls":"turn:global.relay.metered.ca:443","username":"xxx","credential":"xxx"},{"urls":"turns:global.relay.metered.ca:443?transport=tcp","username":"xxx","credential":"xxx"}]
